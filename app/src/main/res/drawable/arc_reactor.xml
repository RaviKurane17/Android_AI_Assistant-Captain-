<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Glow -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#4000E5FF"/>
            <size android:width="80dp" android:height="80dp"/>
        </shape>
    </item>
    <!-- Middle Ring -->
    <item android:bottom="8dp" android:left="8dp" android:right="8dp" android:top="8dp">
        <shape android:shape="oval">
            <stroke android:width="3dp" android:color="#8000E5FF"/>
            <solid android:color="#00000000"/>
        </shape>
    </item>
    <!-- Inner Core -->
    <item android:bottom="20dp" android:left="20dp" android:right="20dp" android:top="20dp">
        <shape android:shape="oval">
            <solid android:color="#00E5FF"/>
            <stroke android:width="1dp" android:color="#FFFFFF"/>
        </shape>
    </item>
</layer-list>
