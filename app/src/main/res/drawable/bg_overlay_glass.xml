<?xml version="1.0" encoding="utf-8"?>
<!-- Frosted dark glass background for the Captain voice overlay panel -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Deep dark navy with high opacity — simulates frosted glass -->
    <solid android:color="#E6050F24" />

    <!-- Rounded top corners only (panel slides from bottom) -->
    <corners
        android:topLeftRadius="28dp"
        android:topRightRadius="28dp"
        android:bottomLeftRadius="0dp"
        android:bottomRightRadius="0dp" />

    <!-- Subtle neon blue border -->
    <stroke
        android:width="1dp"
        android:color="#3300D4FF" />

</shape>
